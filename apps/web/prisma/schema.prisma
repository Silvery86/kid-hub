// ============================================================
// Kid Hub — Prisma Schema
// Source of truth for all database models.
// All types here must align with types/index.ts.
//
// Connection URLs are configured in prisma.config.ts (Prisma v7).
//
// After editing:
//   npx prisma migrate dev --name <description>
//   npx prisma generate
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ── User & Profile ────────────────────────────────────────────

model User {
  id                     String    @id @default(cuid())
  name                   String
  gradeLevel             Int       @default(1)
  avatarUrl              String?
  parentEmail            String?   @unique
  parentPasswordHash     String?
  parentLoginAttempts    Int       @default(0)
  parentLoginLockedUntil DateTime?
  refreshTokenHash       String?
  refreshTokenExpiresAt  DateTime?
  kidPatternHash         String?
  kidPatternAttempts     Int       @default(0)
  kidPatternLockedUntil  DateTime?
  kidAccessSettings      Json?     // Record<string, boolean> — feature toggle state; null = all defaults
  screenTimeLimitMins    Int       @default(120) // daily screen time limit set by parent
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relations
  pin                   ParentPin?
  periods               ClassPeriod[]
  grades                SubjectGrade[]
  progress              UserProgress?
  homeworkCompletions   HomeworkCompletion[]
  mathProgress          MathProgress[]
  englishProgress       EnglishProgress[]
  dailyHomework         DailyHomework[]
  extraClassOverrides   ExtraClassOverride[]
  screenTimeLogs        ScreenTimeLog[]
  activityEvents        ActivityEvent[]

  @@map("users")
}

// ── Parent Auth ───────────────────────────────────────────────

model ParentPin {
  id          String    @id @default(cuid())
  hash        String    // bcrypt hash — raw PIN never stored
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts    Int       @default(0)
  lockedUntil DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("parent_pins")
}

// ── Schedule ──────────────────────────────────────────────────

/// Day of week matches DayOfWeek type in types/index.ts
enum DayOfWeek {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday
}

/// EventType distinguishes recurring school classes from recurring extra classes.
enum EventType {
  SCHOOL_PERIOD
  EXTRA_CLASS
}

model ClassPeriod {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  day          DayOfWeek
  periodNumber Int?      // 1–10 for SCHOOL_PERIOD; null for EXTRA_CLASS
  eventType    EventType @default(SCHOOL_PERIOD)
  subjectId    String    // References SUBJECTS constant in lib/data/subjects.ts
  startTime    String    // "HH:MM" 24-hour format
  endTime      String    // "HH:MM" 24-hour format
  roomNumber   String?
  iconKey      String?   @db.VarChar(30)  // e.g. "english", "music", "backpack"
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  homeworkCompletions HomeworkCompletion[]
  overrides           ExtraClassOverride[]

  // Unique slot per school period; NULL periodNumber rows are excluded by Postgres
  @@unique([userId, day, periodNumber])
  @@index([userId, day])
  @@index([userId, eventType])
  @@map("class_periods")
}

// ── Homework ──────────────────────────────────────────────────

model HomeworkCompletion {
  id        String      @id @default(cuid())
  periodId  String
  period    ClassPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String      // "YYYY-MM-DD" — one record per period per day; no record = not done
  isDone    Boolean     @default(false)
  doneAt    DateTime?
  createdAt DateTime    @default(now())

  @@unique([periodId, date])
  @@index([userId, date])
  @@map("homework_completions")
}

/// One-off homework assignment for a specific date. Not recurring.
model DailyHomework {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String    @db.VarChar(10) // "YYYY-MM-DD"
  subjectId String    @db.VarChar(30)
  label     String    @db.VarChar(150)
  iconKey   String?   @db.VarChar(30)
  isDone    Boolean   @default(false)
  doneAt    DateTime?
  points    Int       @default(10)
  createdAt DateTime  @default(now())

  @@index([userId, date])
  @@map("daily_homework")
}

/// Per-date cancellation of a recurring EXTRA_CLASS slot.
model ExtraClassOverride {
  id        String      @id @default(cuid())
  periodId  String
  period    ClassPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String      @db.VarChar(10) // "YYYY-MM-DD" of the cancellation
  reason    String?     @db.VarChar(100)
  createdAt DateTime    @default(now())

  @@unique([periodId, date])
  @@index([userId, date])
  @@map("extra_class_overrides")
}

// ── Grades ────────────────────────────────────────────────────

/// BadgeTier matches BadgeTier type in types/index.ts
enum BadgeTier {
  excellent
  good
  needs_practice @map("needs-practice")
}

model SubjectGrade {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId    String    // References SUBJECTS constant
  score        Float     // 0–10 scale
  badge        BadgeTier
  semester     Int       // 1 or 2
  academicYear String    // e.g. "2025-2026"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // One grade per subject per semester per year
  @@unique([userId, subjectId, semester, academicYear])
  @@index([userId])
  @@map("subject_grades")
}

// ── Gamification ──────────────────────────────────────────────

model UserProgress {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalPoints    Int      @default(0)
  currentStreak  Int      @default(0)
  lastActiveDate String   // ISO date "YYYY-MM-DD"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  earnedBadges EarnedBadge[]
  bestScores   GameBestScore[]

  @@map("user_progress")
}

model EarnedBadge {
  id             String       @id @default(cuid())
  userProgressId String
  userProgress   UserProgress @relation(fields: [userProgressId], references: [id], onDelete: Cascade)
  badgeId        String       // Static badge ID from lib/data
  earnedAt       DateTime     @default(now())

  @@unique([userProgressId, badgeId])
  @@map("earned_badges")
}

/// GameType matches GameType in types/index.ts
enum GameType {
  math
  english
}

/// MathGameType distinguishes the three math mini-games within the math route.
enum MathGameType {
  counting
  addition
  shapes
}

/// EnglishGameType distinguishes the three English mini-games within the english route.
enum EnglishGameType {
  alphabet
  vocabulary
  phonics
}

model GameBestScore {
  id             String       @id @default(cuid())
  userProgressId String
  userProgress   UserProgress @relation(fields: [userProgressId], references: [id], onDelete: Cascade)
  gameType       GameType
  level          Int          // 1, 2, or 3 — maps to DifficultyLevel
  score          Int
  starsEarned    Int          // 1, 2, or 3
  subType        String?      // "counting" | "addition" | "shapes" for math; "alphabet" | "vocabulary" | "phonics" for english
  achievedAt     DateTime     @default(now())

  // One best score per game + level + subType (subType differentiates math mini-games)
  @@unique([userProgressId, gameType, level, subType])
  @@map("game_best_scores")
}

// ── Math Progress ─────────────────────────────────────────────

/// Records a single completed math mini-game session.
model MathProgress {
  id               String       @id @default(cuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  minigame         MathGameType
  level            Int          // 1, 2, or 3
  correctCount     Int
  incorrectCount   Int
  timeSpentSecs    Int          // Total wall-clock seconds for the session
  starsEarned      Int          // 1–3
  score            Int          // correctCount × 10 × starsEarned
  homeworkPeriodId String?      // FK to ClassPeriod — set when submitted as homework
  homeworkDate     String?      // "YYYY-MM-DD" — mirrors HomeworkCompletion.date
  completedAt      DateTime     @default(now())

  @@index([userId, completedAt])
  @@index([userId, homeworkPeriodId])
  @@map("math_progress")
}

// ── English Progress ──────────────────────────────────────────

/// Records a single completed English mini-game session.
model EnglishProgress {
  id               String          @id @default(cuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  minigame         EnglishGameType // alphabet | vocabulary | phonics
  level            Int             // 1, 2, or 3
  correctCount     Int
  incorrectCount   Int
  timeSpentSecs    Int             // Total wall-clock seconds for the session
  starsEarned      Int             // 1–3, derived from correctCount / totalQuestions
  score            Int             // correctCount × 10 × starsEarned
  homeworkPeriodId String?         // FK to ClassPeriod — set when submitted as homework
  homeworkDate     String?         // "YYYY-MM-DD" — required if homeworkPeriodId set
  completedAt      DateTime        @default(now())

  @@index([userId, completedAt])
  @@index([userId, homeworkPeriodId])
  @@map("english_progress")
}

// ── Screen Time ───────────────────────────────────────────────

/// Accumulates total screen time per kid per day in seconds. One record per (userId, date).
model ScreenTimeLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String   @db.VarChar(10) // "YYYY-MM-DD"
  totalSecs Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@map("screen_time_logs")
}

// ── Activity Feed ─────────────────────────────────────────────

/// Records a significant kid-side event for the parent activity feed.
model ActivityEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @db.VarChar(30)  // GAME_COMPLETE | HOMEWORK_DONE
  label     String   @db.VarChar(150) // human-readable description shown to parent
  iconKey   String?  @db.VarChar(10)  // emoji displayed in the feed
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("activity_events")
}
